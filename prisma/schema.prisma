  total_net        Float     @default(0)
  total_deductions Float     @default(0)
  notes            String?
  processed_by     String?
  processed_at     DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  entries   payroll_entries[]
  processor users?            @relation("payroll_processor", fields: [processed_by], references: [id])

  @@unique([period_month, period_year])
  @@index([status])
}

model payroll_entries {
  id              String   @id @default(cuid())
  run_id          String
  user_id         String
  base_salary     Float    @default(0)
  working_days    Int      @default(0)
  present_days    Int      @default(0)
  overtime_hours  Float    @default(0)
  overtime_amount Float    @default(0)
  bonus_amount    Float    @default(0)
  deductions      Float    @default(0)
  gross_amount    Float    @default(0)
  net_amount      Float    @default(0)
  tax_amount      Float    @default(0)
  // Sprint 3: Payroll x Attendance/Leave integration. paid_leave_days counts
  // toward earned pay (present_days + paid_leave_days, capped at working_days);
  // unpaid_leave_days and absent_days are informational breakdowns only —
  // unpaid leave's cost is already reflected in reduced earned pay (it's
  // simply not added to paid_leave_days), it has no separate deduction line.
  // late_deduction and absence_penalty ARE separate deduction line items,
  // folded into `deductions` alongside tax_amount.
  paid_leave_days     Int   @default(0)
  unpaid_leave_days   Int   @default(0)
  absent_days         Int   @default(0)
  late_violation_count Int  @default(0)
  late_deduction      Float @default(0)
  absence_penalty     Float @default(0)
  // Sprint 3 Milestone 5: Negative Payroll Validation. `net_amount` is never
  // stored below zero -- `calculated_net_amount` retains the true computed
  // value (which may be negative) for audit/validation purposes.
  // validation_status: PASSED | FAILED. A FAILED entry blocks its run from
  // advancing to COMPLETED/PAID (see update_run_status in payroll.controller.js)
  // until corrected and recalculated, but does not stop other employees in
  // the same run from being calculated normally.
  calculated_net_amount Float   @default(0)
  validation_status     String  @default("PASSED")
  validation_reason     String?
  status          String   @default("PENDING")
  payslip_url     String?
  notes           String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  run  payroll_runs @relation(fields: [run_id], references: [id], onDelete: Cascade)
  user users        @relation("payroll_entries", fields: [user_id], references: [id])

  // Sprint 3 Milestone 4: an employee may appear only once per payroll run.
  // Enforced at the database level (not just in application code) so two
  // concurrent "Calculate" requests on the same run can never both create a
  // row for the same employee. This is the canonical upsert key --
  // calculate_run() upserts by this compound key directly, not by a
  // findFirst()-then-upsert-by-id lookup.
  @@unique([run_id, user_id])
  @@index([run_id])
  @@index([user_id])
}

// ─── System Settings ──────────────────────────────────────────────────────────
model system_settings {
  key        String   @id
  value      String
  updated_by String?
  updated_at DateTime @updatedAt
}

// ─── Desktop App Download Analytics ──────────────────────────────────────────
model download_events {
  id         String   @id @default(cuid())
  platform   String // 'windows' | 'mac' | 'linux'
  version    String?
  user_id    String?
  ip_address String?
  user_agent String?
  created_at DateTime @default(now())

  user users? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([platform])
  @@index([user_id])
  @@index([created_at])
}

// ─── App Usage Logs ───────────────────────────────────────────────────────────
model app_usage_logs {
  id               String   @id @default(cuid())
  session_id       String
  user_id          String
  app_name         String
  window_title     String?
  url              String?
  duration_seconds Int      @default(0)
  captured_at      DateTime @default(now())
  created_at       DateTime @default(now())

  user    users               @relation(fields: [user_id], references: [id])
  session screenshot_sessions @relation(fields: [session_id], references: [id])

  @@index([user_id])
  @@index([session_id])
  @@index([captured_at])
}

// ─── Emergency Contacts ────────────────────────────────────────────────────────
// Sprint 1 Phase 2 Milestone 4. Promotes the old flat single-contact fields on
// employee_profiles (emergency_contact_name / _relation / _phone) into a proper
// one-to-many table supporting multiple contacts per employee. The old flat
// fields are intentionally left untouched on employee_profiles — retiring them
// is a future decision, not part of this migration.
model emergency_contacts {
  id         String   @id @default(cuid())
  user_id    String
  name       String
  relation   String
  phone      String
  is_primary Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}
