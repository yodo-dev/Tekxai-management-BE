model messages {
  id         String    @id @default(cuid())
  channel_id String
  user_id    String
  content    String
  parent_id  String?
  file_key   String?
  file_url   String?
  file_name  String?
  file_size  Int?
  mime_type  String?
  is_edited  Boolean   @default(false)
  edited_at  DateTime?
  deleted_at DateTime?
  created_at DateTime  @default(now())

  channel   channels            @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  user      users               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  reactions message_reactions[]
  parent    messages?           @relation("MessageThread", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   messages[]          @relation("MessageThread")

  @@index([channel_id])
  @@index([user_id])
  @@index([created_at])
