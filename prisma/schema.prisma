generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & RBAC ──────────────────────────────────────────────────────────────

model users {
  id             String    @id @default(cuid())
  email          String    @unique
  password_hash  String
  first_name     String?
  last_name      String?
  phone          String?
  avatar         String?
  department_id  String?
  division_id    String?
  position       String?
  designation    String?
  designation_id String?
  grade_id       String?
  salary         Float?
  employee_id    String?   @unique
  status         String    @default("ACTIVE") // Employment Status: ACTIVE | INACTIVE | ON_LEAVE | SUSPENDED | TERMINATED | DECEASED — single write path is set_employment_status(), mirrored into employee_profiles.employment_status
  is_active      Boolean   @default(true)
  hire_date      DateTime?
  business_unit  String?   @default("ERP")
  supervisor_id  String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  deleted_at     DateTime?

  roles                       user_roles[]
  refresh_tokens              auth_refresh_tokens[]
  otp_codes                   otp_codes[]
  settings                    user_settings?
  department                  departments?                  @relation(fields: [department_id], references: [id], onDelete: SetNull)
  division                    divisions?                    @relation(fields: [division_id], references: [id], onDelete: SetNull)
  designation_ref             designations?                 @relation(fields: [designation_id], references: [id], onDelete: SetNull)
  grade                       grades?                       @relation(fields: [grade_id], references: [id], onDelete: SetNull)
  supervisor                  users?                        @relation("user_supervisor", fields: [supervisor_id], references: [id], onDelete: SetNull)
  subordinates                users[]                       @relation("user_supervisor")
  team_memberships            team_members[]
  managed_teams               teams[]                       @relation("team_manager")
  owned_projects              projects[]                    @relation("project_owner")
  led_projects                projects[]                    @relation("project_leader")
  extension_requests_made     extension_requests[]          @relation("extension_requester")
  extension_requests_reviewed extension_requests[]          @relation("extension_reviewer")
  project_memberships         project_members[]
  timesheet_entries           timesheet_entries[]
  time_off_requests           time_off_requests[]
  timesheet_edit_requests     timesheet_edit_requests[]
  user_permissions            user_permissions[]
  invites_sent                invites[]                     @relation("invite_sender")
  redeemed_invite             invites?                      @relation("invite_redeemed_by")
  starred_items               starred_items[]
  notifications               notifications[]
  support_tickets             support_tickets[]
  ticket_replies              ticket_replies[]
  marketing_deals             marketing_deals[]
  salary_builders             salary_builders[]
  upwork_bids                 upwork_bids[]
  linkedin_leads              linkedin_leads[]
  email_leads                 email_leads[]
  linkedin_activity           linkedin_activity[]
  deposits_created            deposits[]
  marketing_targets           marketing_targets[]
  asset_assignments           asset_assignments[]
  asset_requests_made         asset_requests[]              @relation("asset_request_requester")
  asset_requests_for_me       asset_requests[]              @relation("asset_request_target")
  asset_requests_reviewed     asset_requests[]              @relation("asset_request_reviewer")
  daily_reports               daily_progress_reports[]
  performance_scores          employee_performance_scores[]
  performance_reviews         performance_reviews[]
  assigned_tasks              tasks[]                       @relation("task_assignee")
  created_sub_items           task_sub_items[]              @relation("sub_item_creator")
  task_time_logs              task_time_logs[]              @relation("task_time_logs")
  payroll_entries             payroll_entries[]             @relation("payroll_entries")
  processed_runs              payroll_runs[]                @relation("payroll_processor")
  employee_shifts             employee_shifts[]
  attendance_violations       attendance_violations[]
  leave_balances              leave_balances[]
  job_description             job_descriptions?
  activity_logs               activity_logs[]
  screenshot_sessions         screenshot_sessions[]
  screenshots                 screenshots[]
  productivity_sessions       productivity_sessions[]
  file_uploads                file_uploads[]
  onboarding_tasks            onboarding_tasks[]
  offboarding_tasks           offboarding_tasks[]
  contracts                   contracts[]
  policy_acknowledgements     policy_acknowledgements[]
  employee_profile            employee_profiles?
  employee_documents          employee_documents[]
  uploaded_documents          employee_documents[]          @relation("doc_uploader")
  requisitions_raised         requisitions[]                @relation("req_requester")
  requisition_approvals       requisition_approvals[]       @relation("req_approver")
  crm_handoffs_assigned       crm_handoffs[]                @relation("handoff_assignee")
  crm_handoffs_created        crm_handoffs[]                @relation("handoff_creator")
  crm_invoices_created        crm_invoices[]                @relation("invoice_creator")
  project_discussions         project_discussions[]
  channel_memberships         channel_members[]
  messages                    messages[]
  education_records           education_records[]
  employment_history          employment_history[]
  emergency_contacts          emergency_contacts[]
  salary_increments           salary_increments[]
  increments_approved         salary_increments[]           @relation("increment_approver")
  designation_history         designation_history[]
  designation_changes_made    designation_history[]         @relation("designation_history_actor")
  overtime_requests           overtime_requests[]
  overtime_approved           overtime_requests[]           @relation("overtime_approver")
  expense_account             expense_accounts?
  expense_transactions        expense_transactions[]        @relation("expense_txn_user")
  created_expense_txns        expense_transactions[]        @relation("expense_txn_creator")
  financial_reports           financial_reports[]
  download_events             download_events[]
  app_usage_logs              app_usage_logs[]
  two_factor_enabled          Boolean                       @default(false)
  two_factor_secret           String?
  google_id                   String?                       @unique
  created_webhooks            webhooks[]                    @relation("webhook_creator")
  saved_reports               saved_reports[]               @relation("saved_reports_creator")
  google_calendar_token       google_calendar_tokens?
  client_weekly_updates       client_weekly_updates[]
  project_documents_uploaded  project_documents[]

  @@index([department_id])
  @@index([division_id])
  @@index([status])
  @@index([supervisor_id])
  @@index([business_unit])
}

model roles {
  id         String   @id @default(cuid())
  name       String   @unique
  level      Int
  is_system  Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  users   user_roles[]
  invites invites[]
}

model user_roles {
  user_id     String
  role_id     String
  assigned_at DateTime @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role roles @relation(fields: [role_id], references: [id], onDelete: Restrict)

  @@id([user_id, role_id])
  @@index([role_id])
}

// Role-based permission keys: "{workspace}.{module}.{action}"
// e.g. "crm.pipeline.view", "erp.projects.create", "hr.salary.approve"
// Super Admin always bypasses permission checks.
// If no row exists for a role+permission, default is DENY for non-admin roles.
model role_permissions {
  id         String   @id @default(cuid())
  role_name  String // must match ROLE_NAMES constant
  permission String // dot-notation key
  granted    Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([role_name, permission])
  @@index([role_name])
  @@index([permission])
}

// User-level permission overrides — take precedence over role_permissions.
// granted=true → explicit grant even if role denies.
// granted=false → explicit deny even if role allows.
model user_permissions {
  id         String   @id @default(cuid())
  user_id    String
  permission String
  granted    Boolean // true = override grant, false = override deny
  note       String? // optional reason / expiry note
  granted_by String? // user_id of the admin who set this
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, permission])
  @@index([user_id])
  @@index([permission])
}

model auth_refresh_tokens {
  id                     String    @id @default(cuid())
  user_id                String
  token_hash             String    @unique
  expires_at             DateTime
  revoked_at             DateTime?
  replaced_by_token_hash String?
  created_by_ip          String?
  created_by_user_agent  String?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
}

model otp_codes {
  id         String    @id @default(cuid())
  user_id    String
  code       String
  purpose    String
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
}

// ─── Org Structure ────────────────────────────────────────────────────────────

model departments {
  id          String    @id @default(cuid())
  name        String
  code        String?   @unique
  description String?
  manager_id  String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  divisions    divisions[]
  users        users[]
  teams        teams[]
  assets       assets[]
  requisitions requisitions[] @relation("dept_requisitions")
  designations designations[]

  designation_history_previous designation_history[] @relation("designation_history_previous_department")
  designation_history_new      designation_history[] @relation("designation_history_new_department")
}

model divisions {
  id            String    @id @default(cuid())
  department_id String
  name          String
  code          String?   @unique
  description   String?
  manager_id    String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  department departments @relation(fields: [department_id], references: [id], onDelete: Cascade)
  users      users[]
  teams      teams[]
}

model designations {
  id            String    @id @default(cuid())
  name          String
  department_id String?
  is_active     Boolean   @default(true)
  sort_order    Int       @default(0)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  department departments? @relation(fields: [department_id], references: [id], onDelete: SetNull)
  users      users[]

  designation_history_previous designation_history[] @relation("designation_history_previous_designation")
  designation_history_new      designation_history[] @relation("designation_history_new_designation")

  @@index([department_id])
}

model grades {
  id          String    @id @default(cuid())
  name        String    @unique
  level       Int // ordering rank — lower number = more junior (1 = entry level)
  description String?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  users users[]

  designation_history_previous designation_history[] @relation("designation_history_previous_grade")
  designation_history_new      designation_history[] @relation("designation_history_new_grade")

  @@index([level])
}

// ─── User Settings ────────────────────────────────────────────────────────────

model user_settings {
  id                 String   @id @default(cuid())
  user_id            String   @unique
  show_notifications Boolean  @default(true)
  language           String   @default("en")
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// ─── Teams ────────────────────────────────────────────────────────────────────

model teams {
  id            String    @id @default(cuid())
  name          String
  description   String?
  type          String    @default("GENERAL")
  department_id String?
  division_id   String?
  manager_id    String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  department departments?   @relation(fields: [department_id], references: [id], onDelete: SetNull)
  division   divisions?     @relation(fields: [division_id], references: [id], onDelete: SetNull)
  manager    users?         @relation("team_manager", fields: [manager_id], references: [id], onDelete: SetNull)
  members    team_members[]
  projects   projects[]
  invites    invites[]

  @@index([department_id])
}

model team_members {
  id        String   @id @default(cuid())
  team_id   String
  user_id   String
  role      String   @default("MEMBER")
  joined_at DateTime @default(now())

  team teams @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([team_id, user_id])
  @@index([team_id])
  @@index([user_id])
}

// ─── Projects ────────────────────────────────────────────────────────────────

model projects {
  id              String    @id @default(cuid())
  title           String
  description     String?
  status          String    @default("PENDING")
  project_type    String    @default("CLIENT") // CLIENT | INTERNAL. Enterprise Performance Platform M1 — distinguishes revenue-bearing client work from internal/overhead work. See Tekxai-Operations-OS/08-Master-Gap-Analysis.md §11.5.
  progress        Int       @default(0)
  progress_mode   String    @default("MANUAL") // MANUAL | AUTO (auto = computed from milestone completion)
  total_hours     Int       @default(0)
  start_date      DateTime?
  end_date        DateTime?
  owner_id        String?
  leader_id       String?
  team_id         String?
  budget          Float?
  budget_currency String    @default("PKR")
  budget_spent    Float     @default(0)
  client_name     String?
  dev_status      String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  owner              users?                   @relation("project_owner", fields: [owner_id], references: [id], onDelete: SetNull)
  team_leader        users?                   @relation("project_leader", fields: [leader_id], references: [id], onDelete: SetNull)
  team               teams?                   @relation(fields: [team_id], references: [id], onDelete: SetNull)
  members            project_members[]
  tasks              tasks[]
  milestones         milestones[]
  starred_by         starred_items[]
  discussions        project_discussions[]
  crm_handoffs       crm_handoffs[]
  devops_access      devops_access_tracking?
  tracking_links     project_tracking_links[]
  weekly_updates     client_weekly_updates[]
  documents          project_documents[]
  extension_requests extension_requests[]
  invoices           crm_invoices[]

  @@index([owner_id])
  @@index([status])
}

model extension_requests {
  id                String    @id @default(cuid())
  project_id        String
  requested_by      String
  current_deadline  DateTime?
  proposed_deadline DateTime
  reason            String
  status            String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewed_by       String?
  review_reason     String?
  reviewed_at       DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  project   projects @relation(fields: [project_id], references: [id], onDelete: Cascade)
  requester users    @relation("extension_requester", fields: [requested_by], references: [id], onDelete: Cascade)
  reviewer  users?   @relation("extension_reviewer", fields: [reviewed_by], references: [id], onDelete: SetNull)

  @@index([project_id])
  @@index([status])
}

model project_members {
  id         String   @id @default(cuid())
  project_id String
  user_id    String
  role       String   @default("MEMBER")
  joined_at  DateTime @default(now())

  project projects @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user    users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([project_id, user_id])
  @@index([project_id])
  @@index([user_id])
}

model tasks {
  id           String    @id @default(cuid())
  project_id   String
  milestone_id String?
  title        String
  description  String?
  status       String    @default("TODO")
  priority     String    @default("MEDIUM")
  assigned_to  String?
  due_date     DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  project        projects         @relation(fields: [project_id], references: [id], onDelete: Cascade)
  milestone      milestones?      @relation(fields: [milestone_id], references: [id], onDelete: SetNull)
  assignee       users?           @relation("task_assignee", fields: [assigned_to], references: [id], onDelete: SetNull)
  task_sub_items task_sub_items[]
  task_time_logs task_time_logs[]

  @@index([project_id])
  @@index([milestone_id])
  @@index([status])
  @@index([assigned_to])
}

model milestones {
  id          String    @id @default(cuid())
  project_id  String
  title       String
  description String?
  due_date    DateTime?
  completed   Boolean   @default(false)
  blocked     Boolean   @default(false)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  project projects @relation(fields: [project_id], references: [id], onDelete: Cascade)
  tasks   tasks[]

  @@index([project_id])
}

model devops_access_tracking {
  id                        String    @id @default(cuid())
  project_id                String    @unique
  point_of_communication    String    @default("EMAIL") // EMAIL | CLICKUP | SLACK | TEAMS | WHATSAPP | GOOGLE_MEET | ZOOM | OTHER
  progress_shared_to_client Boolean   @default(false) // kept for backward compat; derived from progress_shared_status
  progress_shared_status    String    @default("NOT_SHARED") // NOT_SHARED | SHARED | AWAITING_FEEDBACK | CLIENT_APPROVED
  progress_shared_date      DateTime?
  git_access_status         String    @default("NOT_APPLICABLE") // GRANTED | PENDING | NOT_APPLICABLE
  server_access_status      String    @default("NOT_APPLICABLE")
  domain_access_status      String    @default("NOT_APPLICABLE")
  email_smtp_access_status  String    @default("NOT_APPLICABLE")
  aws_access_status         String    @default("NOT_APPLICABLE") // GRANTED | PENDING | LIMITED | NOT_APPLICABLE
  devops_remarks            String?
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt

  project projects @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
}

model project_tracking_links {
  id         String   @id @default(cuid())
  project_id String
  link_type  String // CLICKUP | GOOGLE_SHEET | NOTION | JIRA | GITHUB_PROJECT | LINEAR | OTHER
  label      String?
  url        String
  created_by String?
  created_at DateTime @default(now())

  project projects @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
}

model client_weekly_updates {
  id              String   @id @default(cuid())
  project_id      String
  update_date     DateTime @default(now())
  updated_by      String?
  method          String   @default("EMAIL") // same values as devops_access_tracking.point_of_communication
  summary         String
  client_response String?
  created_at      DateTime @default(now())

  project projects @relation(fields: [project_id], references: [id], onDelete: Cascade)
  updater users?   @relation(fields: [updated_by], references: [id], onDelete: SetNull)

  @@index([project_id])
}

model project_documents {
  id            String   @id @default(cuid())
  project_id    String
  document_type String   @default("OTHER") // CONTRACT | SCOPE | PROPOSAL | SOW | WIREFRAME | ARCHITECTURE | MEETING_NOTES | OTHER
  title         String
  file_key      String?
  file_url      String?
  notes         String?
  uploaded_by   String?
  created_at    DateTime @default(now())

  project  projects @relation(fields: [project_id], references: [id], onDelete: Cascade)
  uploader users?   @relation(fields: [uploaded_by], references: [id], onDelete: SetNull)

  @@index([project_id])
}

// ─── Starred Items ────────────────────────────────────────────────────────────

model starred_items {
  id         String   @id @default(cuid())
  user_id    String
  item_type  String
  item_id    String
  project_id String?
  created_at DateTime @default(now())

  user    users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  project projects? @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@unique([user_id, item_type, item_id])
  @@index([user_id])
  @@index([item_type])
}

// ─── Timesheets ───────────────────────────────────────────────────────────────

model timesheet_entries {
  id              String    @id @default(cuid())
  user_id         String
  check_in        DateTime
  check_out       DateTime?
  duration_sec    Int       @default(0)
  status          String    @default("IN_PROGRESS")
  note            String?
  checkout_reason String? // MANUAL | LOGOUT | IDLE_TIMEOUT | ADMIN
  checkout_source String? // WEB | SYSTEM | ADMIN_PORTAL
  is_wfh          Boolean?  @default(false)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  user          users                     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  edit_requests timesheet_edit_requests[]

  @@index([user_id])
  @@index([check_in])
  @@index([status])
}

model timesheet_edit_requests {
  id            String    @id @default(cuid())
  entry_id      String
  user_id       String
  new_check_in  DateTime?
  new_check_out DateTime?
  reason        String
  status        String    @default("PENDING")
  reviewed_by   String?
  reviewed_at   DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  entry timesheet_entries @relation(fields: [entry_id], references: [id], onDelete: Cascade)
  user  users             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([entry_id])
  @@index([user_id])
  @@index([status])
}

model time_off_policies {
  id           String   @id @default(cuid())
  name         String
  description  String?
  days_allowed Int      @default(0)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  requests       time_off_requests[]
  leave_balances leave_balances[]
}

model time_off_requests {
  id              String    @id @default(cuid())
  user_id         String
  policy_id       String
  leave_type      String? // ANNUAL | MARRIAGE | UMRAH | MATERNITY | PATERNITY | SICK | UNPAID | OTHER
  start_date      DateTime
  end_date        DateTime
  days            Int       @default(1)
  reason          String
  status          String    @default("PENDING")
  manager_comment String?
  reviewed_by     String?
  reviewed_at     DateTime?
  // policy flags (computed at create/review time)
  is_monday_start Boolean?  @default(false)
  is_friday_end   Boolean?  @default(false)
  is_sandwich     Boolean?  @default(false)
  effective_days  Int? // after Mon/Fri/sandwich multipliers
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  user   users             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  policy time_off_policies @relation(fields: [policy_id], references: [id], onDelete: Restrict)

  @@index([user_id])
  @@index([status])
  @@index([start_date])
}

// ─── Invites ─────────────────────────────────────────────────────────────────

model invites {
  id             String    @id @default(cuid())
  email          String
  token          String    @unique @default(cuid())
  role_id        String
  team_id        String?
  department     String?
  designation    String?
  status         String    @default("PENDING")
  invited_by     String
  expires_at     DateTime
  used_at        DateTime?
  redeemed_by_id String?   @unique
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  role        roles  @relation(fields: [role_id], references: [id], onDelete: Restrict)
  team        teams? @relation(fields: [team_id], references: [id], onDelete: SetNull)
  inviter     users  @relation("invite_sender", fields: [invited_by], references: [id], onDelete: Cascade)
  redeemed_by users? @relation("invite_redeemed_by", fields: [redeemed_by_id], references: [id])

  @@index([email])
  @@index([token])
  @@index([status])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model notifications {
  id         String   @id @default(cuid())
  user_id    String
  title      String
  message    String
  type       String   @default("info")
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

