model salary_increments {
  id                           String    @id @default(cuid())
  user_id                      String
  review_year                  Int
  review_period                String // e.g. "2025-01 to 2025-12"
  effective_date               DateTime?
  previous_salary              Float
  mandatory_pct                Float     @default(5)
  performance_pct              Float     @default(0)
  regularity_pct               Float     @default(0)
  punctuality_pct              Float     @default(0)
  total_pct                    Float     @default(0)
  increment_amount             Float?
  new_salary                   Float?
  status                       String    @default("DRAFT") // DRAFT | PENDING | APPROVED | REJECTED
  approved_by                  String?
  approved_at                  DateTime?
  notes                        String?
  // Snapshot of metrics used for calculation
  leave_count_snapshot         Int?
  latecoming_count_snapshot    Int?
  performance_score_snapshot   Float?
  regularity_eligible          Boolean   @default(true)
  punctuality_eligible         Boolean   @default(true)
