// ─── Asset Management ─────────────────────────────────────────────────────────

model asset_categories {
  id            String   @id @default(cuid())
  name          String   @unique
  code          String   @unique
  description   String?
  is_device     Boolean  @default(false)
  is_assignable Boolean  @default(true)
  is_active     Boolean  @default(true)
  sort_order    Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  assets   assets[]
  requests asset_requests[]
}

model asset_vendors {
  id           String   @id @default(cuid())
  name         String
  contact_info String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  assets assets[]
}

model asset_locations {
  id          String   @id @default(cuid())
  office      String
  floor       String?
  room        String?
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  assets assets[]
}

model assets {
  id              String    @id @default(cuid())
  asset_tag       String    @unique
  name            String
  brand           String?
  model           String?
  serial_number   String?
  category_id     String
  vendor_id       String?
  location_id     String?
  department_id   String?
  status          String    @default("AVAILABLE")
  purchase_date   DateTime?
  purchase_cost   Float?
  warranty_expiry DateTime?
  notes           String?
  condition       String?
  processor       String?
  ram             String?
  storage         String?
  storage_type    String?
  generation      String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  category    asset_categories         @relation(fields: [category_id], references: [id], onDelete: Restrict)
  vendor      asset_vendors?           @relation(fields: [vendor_id], references: [id], onDelete: SetNull)
  location    asset_locations?         @relation(fields: [location_id], references: [id], onDelete: SetNull)
  department  departments?             @relation(fields: [department_id], references: [id], onDelete: SetNull)
  assignments asset_assignments[]
  maintenance asset_maintenance_logs[]
  disposals   asset_disposals[]

  @@index([category_id])
  @@index([status])
  @@index([department_id])
}

model asset_assignments {
  id                 String    @id @default(cuid())
  asset_id           String
  user_id            String
  assigned_at        DateTime  @default(now())
  return_date        DateTime?
  returned_at        DateTime?
  returned_condition String?
  notes              String?
  assigned_by        String?
  is_active          Boolean   @default(true)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  asset assets @relation(fields: [asset_id], references: [id], onDelete: Cascade)
  user  users  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([asset_id])
  @@index([user_id])
  @@index([is_active])
}

model asset_maintenance_logs {
  id            String    @id @default(cuid())
  asset_id      String
  type          String
  description   String
  cost          Float?
  performed_by  String?
  performed_at  DateTime  @default(now())
  next_due_date DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  asset assets @relation(fields: [asset_id], references: [id], onDelete: Cascade)

  @@index([asset_id])
}

model asset_disposals {
  id            String   @id @default(cuid())
  asset_id      String
  reason        String
  disposal_date DateTime
  disposed_by   String?
  notes         String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  asset assets @relation(fields: [asset_id], references: [id], onDelete: Cascade)

  @@index([asset_id])
}

model asset_requests {
  id                    String    @id @default(cuid())
  user_id               String
  requested_for_user_id String?
  asset_category_id     String
  reason                String?
  status                String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewed_by           String?
  reviewed_at           DateTime?
  rejection_reason      String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  requester     users            @relation("asset_request_requester", fields: [user_id], references: [id], onDelete: Cascade)
  requested_for users?           @relation("asset_request_target", fields: [requested_for_user_id], references: [id], onDelete: SetNull)
  reviewer      users?           @relation("asset_request_reviewer", fields: [reviewed_by], references: [id], onDelete: SetNull)
  category      asset_categories @relation(fields: [asset_category_id], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([user_id])
  @@index([asset_category_id])
}

