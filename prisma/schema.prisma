// ─── Employee Extended HR Profile ─────────────────────────────────────────────

model employee_profiles {
  id                         String    @id @default(cuid())
  user_id                    String    @unique
  profile_status             String?   @default("ACTIVE") // DRAFT | ACTIVE
  // ── Personal ──────────────────────────────────────────────────────────
  personal_email             String?
  cnic                       String?
  dob                        DateTime?
  gender                     String?
  marital_status             String?
  father_name                String?
  alternate_phone            String?
  nationality                String?
  religion                   String?
  blood_group                String?
  current_address            String?
  permanent_address          String?
  emergency_contact_name     String?
  emergency_contact_relation String?
  emergency_contact_phone    String?
  // ── Employment ────────────────────────────────────────────────────────
  employment_type            String?   @default("FULL_TIME")
  employment_status          String?   @default("ACTIVE") // Employment Status: ACTIVE | INACTIVE | ON_LEAVE | SUSPENDED | TERMINATED | DECEASED — mirrors users.status, single write path is set_employment_status(); Employee Lifecycle (a separate journey field) owns Probation/Onboarding/Notice Period/etc.
  lifecycle_stage            String? // Employee Lifecycle: ONBOARDING | PROBATION | ACTIVE_EMPLOYMENT | NOTICE_PERIOD | EXIT_CLEARANCE | ARCHIVED — People-owned journey field, independent from employment_status. No DB default: new hires get ONBOARDING set explicitly by employee-lifecycle.service.js, not fabricated for pre-existing rows. Single write path is set_lifecycle_stage().
  grade                      String?
  work_mode                  String?   @default("ONSITE")
  probation_start            DateTime?
  probation_end              DateTime?
  probation_status           String?
  confirmation_date          DateTime?
  resignation_date           DateTime?
  termination_date           DateTime?
  notice_period_days         Int?
  // ── Work Info ─────────────────────────────────────────────────────────
  work_location              String?
  office_branch              String?
  floor_area                 String?
  working_days               Json? // ["MON","TUE","WED","THU","FRI"]
  weekend                    String?
  work_start                 String? // "09:00"
  work_end                   String? // "18:00"
  lunch_break_min            Int?
  work_extension             String?
  work_phone                 String?
  is_remote                  Boolean?  @default(false)
  office_location            String?
  // ── Compensation ──────────────────────────────────────────────────────
  salary_currency            String?   @default("PKR")
  base_salary                Float?
  gross_salary               Float?
  effective_salary_date      DateTime?
  pay_frequency              String?   @default("MONTHLY") // MONTHLY | BI_MONTHLY | WEEKLY
  // ── General ───────────────────────────────────────────────────────────
  notes                      String?
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

