  punctuality_exclusion_reason String?
  created_by                   String?
  created_at                   DateTime  @default(now())
  updated_at                   DateTime  @updatedAt

  user     users  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  approver users? @relation("increment_approver", fields: [approved_by], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([review_year])
  @@index([status])
}

// ─── Designation History (Sprint 1 Phase 4 Milestone 1) ───────────────────────
// Promotion/Transfer audit trail. Modeled on salary_increments above: one
// record per change, before/after value pair(s), effective date, actor.
// The single write path is record_designation_change() in
// users.repository.js — a designation/grade/department change must never
// go through the generic update_existing_user() field patch again.
model designation_history {
  id                      String    @id @default(cuid())
  user_id                 String
  previous_designation_id String?
  new_designation_id      String?
  previous_grade_id       String?
  new_grade_id            String?
  previous_department_id  String?
  new_department_id       String?
  change_type             String // PROMOTION | TRANSFER | PROMOTION_AND_TRANSFER
  effective_date          DateTime?
  reason                  String?
  changed_by              String
  created_at              DateTime  @default(now())

  user                 users         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  actor                users         @relation("designation_history_actor", fields: [changed_by], references: [id], onDelete: Cascade)
  previous_designation designations? @relation("designation_history_previous_designation", fields: [previous_designation_id], references: [id], onDelete: SetNull)
  new_designation      designations? @relation("designation_history_new_designation", fields: [new_designation_id], references: [id], onDelete: SetNull)
  previous_grade       grades?       @relation("designation_history_previous_grade", fields: [previous_grade_id], references: [id], onDelete: SetNull)
  new_grade            grades?       @relation("designation_history_new_grade", fields: [new_grade_id], references: [id], onDelete: SetNull)
  previous_department  departments?  @relation("designation_history_previous_department", fields: [previous_department_id], references: [id], onDelete: SetNull)
  new_department       departments?  @relation("designation_history_new_department", fields: [new_department_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([change_type])
  @@index([effective_date])
}

