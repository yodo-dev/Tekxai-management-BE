{
  "name": "tekxai-management-be",
  "version": "2.0.0",
  "description": "Tekxai ERP Backend",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "start:dev": "NODE_ENV=development node src/server.js",
    "start:prod": "NODE_ENV=production node src/server.js",
    "dev": "NODE_ENV=development node --watch src/server.js",
    "db:generate": "prisma generate",
    "db:migrate:dev": "NODE_ENV=development prisma migrate dev",
    "db:migrate:prod": "NODE_ENV=production prisma migrate deploy",
    "db:push": "NODE_ENV=development prisma db push",
    "db:studio": "NODE_ENV=development prisma studio",
    "db:reset": "NODE_ENV=development prisma migrate reset",
    "db:seed": "NODE_ENV=development node prisma/seeders/index.js",
    "test": "node --import ./tests/setup.js --test tests/**/*.test.js"
  },
  "prisma": {
    "seed": "node prisma/seeders/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "prisma": "^7.8.0"
  },
  "overrides": {
    "fast-uri": "^4.0.1",
    "uuid": ">=11.1.1",
    "hono": "^4.7.11",
    "@hono/node-server": "^1.14.3"
  }
}
